############################################
.venv/
venv/
env/
ENV/
.python-version

############################################
# Distribution / packaging
############################################
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
wheels/
*.whl

############################################
# Editable install leftovers
############################################
*.egg
*.egg-link

############################################
# Pytest
############################################
.pytest_cache/
.coverage
coverage.xml
htmlcov/

############################################
# Type checkers / linters
############################################
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

############################################
# Logs & runtime
############################################
*.log
*.out
*.pid

############################################
# IDEs / Editors
############################################
# VSCode
.vscode/

# PyCharm / IntelliJ
.idea/
*.iml

# Sublime / others
*.sublime-project
*.sublime-workspace

############################################
# OS files
############################################
.DS_Store
Thumbs.db
desktop.ini

############################################
